# Claude API key — get one at https://platform.claude.com
# If unset, the server runs in offline SIMULATION mode (the brain still animates).
ANTHROPIC_API_KEY=

# Model powering the reasoning engine
BRAIN_MODEL=claude-opus-4-8

# Server port
PORT=8787

# Path of the persistent long-term memory store
MEMORY_FILE=./data/memory.json
